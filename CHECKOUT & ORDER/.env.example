APP_NAME="Checkout Order Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=checkout-order-db
DB_PORT=3306
DB_DATABASE=checkout_order_service
DB_USERNAME=checkout_user
DB_PASSWORD=checkout_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

IAE_SERVICE_NAME=Checkout-Order-Service
IAE_API_VERSION=v1
IAE_API_KEY=KEY-MHS-343
IAE_TEAM_ID=TEAM-01

IAE_CENTRAL_BASE_URL=https://iae-sso.virtualfri.id
IAE_CENTRAL_API_KEY=KEY-MHS-343
IAE_CENTRAL_BEARER_TOKEN=
IAE_CENTRAL_TOKEN_URL=https://iae-sso.virtualfri.id/api/v1/auth/token
IAE_CENTRAL_TIMEOUT=5

CART_PROMO_SERVICE_URL=http://cart-promo-app:8000
CART_PROMO_API_KEY=KEY-MHS-343
PRODUCT_SERVICE_URL=http://product-stock-app:8000
PRODUCT_SERVICE_API_KEY=KEY-MHS-343
PRODUCT_STOCK_VALIDATION=false
PRODUCT_STOCK_DEDUCTION=false
SERVICE_HTTP_TIMEOUT=5

SSO_ENABLED=false
SSO_PROVIDER=cloud-dosen
SSO_BASE_URL=https://iae-sso.virtualfri.id
SSO_JWT_ALGORITHM=RS256
SSO_VERIFY_SIGNATURE=true
SSO_JWT_SECRET=
SSO_JWT_PUBLIC_KEY=
SSO_JWKS_URL=https://iae-sso.virtualfri.id/api/v1/auth/jwks
SSO_ISSUER=
SSO_AUDIENCE=
SSO_ROLE_CLAIM=role

LEGACY_AUDIT_ENABLED=false
LEGACY_AUDIT_ENDPOINT=https://iae-sso.virtualfri.id/soap/v1/audit
LEGACY_AUDIT_SOAP_ACTION=SubmitOrderAudit
LEGACY_AUDIT_ACTIVITY_NAME=CheckoutOrderCreated
LEGACY_AUDIT_TIMEOUT=5

RABBITMQ_ENABLED=false
RABBITMQ_PUBLISH_URL=https://iae-sso.virtualfri.id/api/v1/messages/publish
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=iae.central.exchange
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_ROUTING_KEY=checkout.order.created
